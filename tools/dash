#!/usr/bin/env bash
# ============================================================================
# tools/dash — unified CLI for the bamr87 development dash
#
# A thin dispatcher that REUSES existing tooling rather than reimplementing it:
#   setup.sh, run-all-tests.sh, update-submodules.sh, dash-gen, check-drift.sh,
#   and the scripts/ submodule (forkme, stashme, project-init, git_init).
#
# Usage: tools/dash <command> [args]
# ============================================================================
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOLS="${ROOT}/tools"
SCRIPTS="${ROOT}/projects/scripts"   # the scripts submodule lives under projects/

c_bold=$'\033[1m'; c_dim=$'\033[2m'; c_off=$'\033[0m'

usage() {
  cat <<EOF
${c_bold}dash${c_off} — central CLI for the bamr87 development dash

  ${c_bold}dash status${c_off}            submodule + registry + drift summary
  ${c_bold}dash audit [name]${c_off}      standardization conformance matrix (--gate to fail on gaps)
  ${c_bold}dash monitor${c_off}           refresh health and print repos needing attention
  ${c_bold}dash actions [--days N]${c_off} GitHub Actions usage analytics (cost/effectiveness by workflow)
  ${c_bold}dash actions-review${c_off}    triage worst workflows → reviewer work order (feeds actions-review.yml)
  ${c_bold}dash daily${c_off}             prior-day fleet activity digest + failure work order (feeds daily-repo-analysis.yml)
  ${c_bold}dash triage${c_off}            fleet-wide open issues/PRs/CI snapshot → _data/fleet_triage.yml (/triage/ portal)
  ${c_bold}dash serve${c_off}             serve the Jekyll dash locally (docker, :4000)
  ${c_bold}dash sync${c_off}              update submodules + regenerate dash data
  ${c_bold}dash foreach <cmd...>${c_off}  run a shell command in every checked-out submodule
  ${c_bold}dash run <tool> [args]${c_off} run a scripts/ submodule tool (forkme, stashme, ...)
  ${c_bold}dash new <name> [args]${c_off}  scaffold a new project and register it
  ${c_bold}dash adopt-release <repo>${c_off} scaffold the release-please pipeline (--all for active repos)
  ${c_bold}dash protect <repo>${c_off}    require the CI gate on a repo's default branch (--all)
  ${c_bold}dash evolve [args]${c_off}     trigger the AI evolution workflow
  ${c_bold}dash ai${c_off}                shadow-priced Claude Code usage per repo (local)
  ${c_bold}dash doctor${c_off}            environment checks (setup.sh --dry-run)
  ${c_bold}dash test${c_off}              run the aggregate test suite
  ${c_bold}dash gen <health|readme|ai|ai-usage|actions|actions-review|daily|triage|all>${c_off}  run the registry generator
  ${c_bold}dash help${c_off}             this help
EOF
}

cmd_status() {
  echo "${c_bold}== Submodules ==${c_off}"
  git -C "$ROOT" submodule status || true
  echo
  echo "${c_bold}== Registry ==${c_off}"
  if command -v python3 >/dev/null; then
    python3 - "$ROOT/_data/projects.yml" <<'PY'
import sys, yaml
with open(sys.argv[1]) as fh:
    reg = yaml.safe_load(fh) or []
print(f"  {len(reg)} projects "
      f"({sum(1 for p in reg if p.get('submodule_path'))} submodules, "
      f"{sum(1 for p in reg if p.get('featured'))} featured, "
      f"{sum(1 for p in reg if p.get('status')=='active')} active)")
PY
  fi
  echo
  echo "${c_bold}== Drift ==${c_off}"
  "${TOOLS}/check-drift.sh" --report || true
}

cmd_monitor() {
  "${TOOLS}/dash-gen" health
  local health="${ROOT}/_data/project_health.yml"
  [[ -f "$health" ]] || { echo "no health data"; return 1; }
  python3 - "$health" <<'PY'
import sys, yaml
data = yaml.safe_load(open(sys.argv[1])) or []
order = {"red":0,"amber":1,"green":2}
for h in sorted(data, key=lambda x: x.get("attention_rank", 2)):
    lvl = h["attention"]["level"]
    dot = {"red":"🔴","amber":"🟠","green":"🟢"}[lvl]
    if lvl == "green":
        continue
    print(f'{dot} {h["name"]:<22} {"; ".join(h["attention"]["reasons"])}')
green = sum(1 for h in data if h["attention"]["level"]=="green")
print(f'\n🟢 {green} healthy / {len(data)} total')
PY
}

cmd_serve() {
  cd "$ROOT"
  if docker compose ps >/dev/null 2>&1; then
    docker compose up -d devenv
    docker compose exec devenv bash -lc \
      'cd /workspace && bundle install && bundle exec jekyll serve -H 0.0.0.0 -c _config.yml,_config_dev.yml'
  else
    echo "Docker not available; serving natively."
    cd "$ROOT" && bundle install && bundle exec jekyll serve -c _config.yml,_config_dev.yml
  fi
}

cmd_sync() {
  "${TOOLS}/update-submodules.sh" "$@"
  "${TOOLS}/dash-gen" all
}

cmd_run() {
  [[ $# -ge 1 ]] || { echo "usage: dash run <tool> [args]"; return 1; }
  local tool="$1"; shift
  for cand in "${SCRIPTS}/${tool}" "${SCRIPTS}/${tool}.sh" "$(command -v "$tool" 2>/dev/null || true)"; do
    if [[ -n "$cand" && -x "$cand" ]]; then exec "$cand" "$@"; fi
  done
  echo "tool not found in scripts/: ${tool}" >&2
  echo "available:" >&2; ls "${SCRIPTS}" 2>/dev/null | sed 's/^/  /' >&2
  return 1
}

cmd_new() {
  [[ $# -ge 1 ]] || { echo "usage: dash new <name> [project-init args]"; return 1; }
  local name="$1"; shift
  if [[ -x "${SCRIPTS}/project-init.sh" ]]; then
    "${SCRIPTS}/project-init.sh" "$name" "$@"
  else
    echo "scripts/project-init.sh not found (is the submodule initialized?)" >&2
    return 1
  fi
  echo
  echo "${c_dim}Remember to register '${name}' in _data/projects.yml"
  echo "(or run the .claude/skills/update-registry skill).${c_off}"
}

cmd_evolve() {
  if command -v gh >/dev/null; then
    gh workflow run unified-evolution.yml "$@"
  else
    echo "gh CLI required to trigger unified-evolution.yml" >&2
    return 1
  fi
}

cmd_audit()  { "${TOOLS}/audit-standards.sh" "$@"; }

# Run a shell command in every checked-out submodule (continue on error).
cmd_foreach() {
  [[ $# -ge 1 ]] || { echo "usage: dash foreach <command...>"; return 1; }
  local cmd="$*" rc=0 name dir
  while IFS= read -r sp; do
    dir="${ROOT}/${sp}"
    name="$(basename "$sp")"
    if [[ ! -d "$dir" ]] || [[ -z "$(ls -A "$dir" 2>/dev/null)" ]]; then
      echo "${c_dim}-- skip ${name} (not checked out)${c_off}"; continue
    fi
    echo "${c_bold}== ${name} ==${c_off}"
    ( cd "$dir" && name="$name" sm_path="$sp" bash -c "$cmd" ) || { rc=1; echo "${c_dim}   (exit $?)${c_off}"; }
  done < <(git -C "$ROOT" config -f .gitmodules --get-regexp '\.path$' | awk '{print $2}')
  return $rc
}

# Active-tier, non-fork submodule names (the release/protect candidates).
_active_repos() {
  "${TOOLS}/audit-standards.sh" --json --no-color 2>/dev/null \
    | python3 -c 'import sys,json;print("\n".join(r["name"] for r in json.load(sys.stdin)["rows"] if r["tier"]=="active"))'
}

cmd_adopt_release() {
  if [[ "${1:-}" == "--all" ]]; then
    shift
    local r
    for r in $(_active_repos); do
      echo "${c_bold}== adopt-release: ${r} ==${c_off}"
      "${TOOLS}/adopt-release.sh" "$r" "$@" || echo "${c_dim}   (skipped ${r})${c_off}"
    done
  else
    "${TOOLS}/adopt-release.sh" "$@"
  fi
}

cmd_protect() {
  if [[ "${1:-}" == "--all" ]]; then
    shift
    local r
    for r in $(_active_repos); do
      echo "${c_bold}== protect: ${r} ==${c_off}"
      "${TOOLS}/protect-branch.sh" "$r" "$@" || echo "${c_dim}   (skipped ${r})${c_off}"
    done
  else
    "${TOOLS}/protect-branch.sh" "$@"
  fi
}

cmd_ai()     { "${TOOLS}/dash-gen" ai "$@"; }
cmd_actions() { "${TOOLS}/dash-gen" actions "$@"; }
cmd_actions_review() { "${TOOLS}/dash-gen" actions-review "$@"; }
cmd_daily() { "${TOOLS}/dash-gen" daily "$@"; }
cmd_triage() { "${TOOLS}/dash-gen" triage "$@"; }
cmd_doctor() { "${TOOLS}/setup.sh" --dry-run "$@"; }
cmd_test()   { "${TOOLS}/run-all-tests.sh" "$@"; }
cmd_gen()    { "${TOOLS}/dash-gen" "$@"; }

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    status)  cmd_status "$@" ;;
    audit)   cmd_audit "$@" ;;
    monitor) cmd_monitor "$@" ;;
    actions) cmd_actions "$@" ;;
    actions-review) cmd_actions_review "$@" ;;
    daily)   cmd_daily "$@" ;;
    triage)  cmd_triage "$@" ;;
    serve)   cmd_serve "$@" ;;
    sync)    cmd_sync "$@" ;;
    foreach) cmd_foreach "$@" ;;
    run)     cmd_run "$@" ;;
    new)     cmd_new "$@" ;;
    adopt-release) cmd_adopt_release "$@" ;;
    protect) cmd_protect "$@" ;;
    evolve)  cmd_evolve "$@" ;;
    ai)      cmd_ai "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    test)    cmd_test "$@" ;;
    gen)     cmd_gen "$@" ;;
    help|-h|--help) usage ;;
    *) echo "unknown command: ${cmd}" >&2; usage; return 1 ;;
  esac
}

main "$@"
