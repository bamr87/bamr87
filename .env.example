# ============================================================================
# bamr87 Monorepo - Environment Configuration
# ============================================================================
#
# Copy this file to .env and edit with your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# CV Builder (Vite / React)
# ---------------------------------------------------------------------------
CV_PORT=5000
VITE_HMR_PORT=5173

# ---------------------------------------------------------------------------
# MkDocs / Documentation
# ---------------------------------------------------------------------------
MKDOCS_PORT=8000

# ---------------------------------------------------------------------------
# Jekyll
# ---------------------------------------------------------------------------
JEKYLL_PORT=4000

# ---------------------------------------------------------------------------
# Wiki.js
# ---------------------------------------------------------------------------
WIKI_PORT=3000
WIKI_DB_USER=wikijs
WIKI_DB_PASS=wikijsrocks
WIKI_DB_NAME=wiki
WIKI_ADMIN_EMAIL=admin@example.com
WIKI_SITE_URL=http://localhost:3000
WIKI_UPGRADE_COMPANION=0

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_PORT=5432

# ---------------------------------------------------------------------------
# Redis (optional, profile: full)
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# pgAdmin (optional, profile: admin)
# ---------------------------------------------------------------------------
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# API Keys (add your own, never commit real values)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# GITHUB_TOKEN=
